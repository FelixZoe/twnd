              v-if="previewIndex > 0"
              class="lightbox-nav lightbox-prev"
              @click="previewPrev"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M15 19L8 12L15 5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <!-- 内容 -->
