<script setup>
import { ref, reactive, computed, onMounted, onUnmounted, nextTick } from 'vue'
import { uploadFileLibrary, getFileList, getFileStats, deleteFile, batchDeleteFiles } from '@/api/file'

/* ========== 状态 ========== */
const loading = ref(false)
const uploadLoading = ref(false)
const fileList = ref([])
const stats = ref([])
const selectedFiles = ref([])
const previewVisible = ref(false)
const previewUrl = ref('')
const previewType = ref('')
const previewName = ref('')
const previewIndex = ref(-1)
const isDragging = ref(false)
const viewMode = ref('grid') // grid / list
const searchKeyword = ref('')
const uploadProgress = ref(0)
const uploadFileName = ref('')
const renameVisible = ref(false)
const renameTarget = ref(null)
const renameNewName = ref('')

const pagination = reactive({
  page: 1,
  pageSize: 24,
  total: 0,
})

const filter = reactive({
  category: '',
})

/* ========== 分类 Tab ========== */
const categoryIcons = {
  '': 'icon-folder',
  image: 'icon-image-fill',
  audio: 'icon-music',
  video: 'icon-eye',
  text: 'icon-bianjiwenzhang_huaban',
  pdf: 'icon-bianjiwenzhang_huaban',
  word: 'icon-bianjiwenzhang_huaban',
  excel: 'icon-bianjiwenzhang_huaban',
  archive: 'icon-folder',
  font: 'icon-bianjiwenzhang_huaban',
  lyric: 'icon-music',
  other: 'icon-folder',
}

const catMap = {
  image: '图片',
  audio: '音频',
  video: '视频',
  text: '文本',
  pdf: 'PDF',
  word: 'Word',
  excel: 'Excel',
  archive: '压缩包',
  font: '字体',
  lyric: '歌词',
  other: '其他',
}

const categories = computed(() => {
  const cats = [{ label: '全部', value: '', count: 0, size: 0 }]
  if (stats.value.length) {
    const allStat = stats.value.find((s) => s.category === 'all')
    if (allStat) {
      cats[0].count = allStat.count
      cats[0].size = allStat.size
    }
    stats.value
      .filter((s) => s.category !== 'all')
      .forEach((s) => {
        cats.push({
          label: catMap[s.category] || s.category,
          value: s.category,
          count: s.count,
          size: s.size,
        })
      })
  }
  return cats
})

/* 总存储使用 */
const totalUsage = computed(() => {
  const allStat = stats.value.find((s) => s.category === 'all')
  return allStat ? allStat.size : 0
})

/* 搜索过滤 */
const filteredFileList = computed(() => {
  if (!searchKeyword.value.trim()) return fileList.value
  const kw = searchKeyword.value.toLowerCase().trim()
  return fileList.value.filter((f) => f.name.toLowerCase().includes(kw))
})

/* 可预览列表（用于 lightbox 翻页） */
const previewableFiles = computed(() =>
  filteredFileList.value.filter((f) => isImage(f.extension) || isAudio(f.extension) || isVideo(f.extension))
)

/* ========== 工具函数 ========== */
const formatSize = (bytes) => {
  if (!bytes || bytes === 0) return '0 B'
  const units = ['B', 'KB', 'MB', 'GB']
  let i = 0
  let size = bytes
  while (size >= 1024 && i < units.length - 1) {
    size /= 1024
    i++
  }
  return size.toFixed(i > 0 ? 1 : 0) + ' ' + units[i]
}

const formatDate = (ts) => {
  if (!ts) return '-'
  const d = new Date(ts)
  const pad = (n) => String(n).padStart(2, '0')
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`
}

const formatDateShort = (ts) => {
  if (!ts) return '-'
  const d = new Date(ts)
  const pad = (n) => String(n).padStart(2, '0')
  return `${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`
}

const isImage = (ext) => ['jpg', 'jpeg', 'png', 'gif', 'webp', 'bmp', 'svg', 'ico', 'avif'].includes(ext)
const isAudio = (ext) => ['mp3', 'wav', 'ogg', 'aac', 'flac', 'm4a', 'wma'].includes(ext)
const isVideo = (ext) => ['mp4', 'avi', 'mov', 'mkv', 'wmv', 'flv', 'webm'].includes(ext)

const getFileIcon = (ext) => {
  if (isImage(ext)) return 'icon-image-fill'
  if (isAudio(ext)) return 'icon-music'
  if (isVideo(ext)) return 'icon-eye'
  if (['pdf'].includes(ext)) return 'icon-bianjiwenzhang_huaban'
  if (['doc', 'docx'].includes(ext)) return 'icon-bianjiwenzhang_huaban'
  if (['xls', 'xlsx'].includes(ext)) return 'icon-bianjiwenzhang_huaban'
  if (['zip', 'rar', '7z', 'tar', 'gz'].includes(ext)) return 'icon-folder'
  if (['ttf', 'otf', 'woff', 'woff2'].includes(ext)) return 'icon-bianjiwenzhang_huaban'
  if (['lrc', 'krc'].includes(ext)) return 'icon-music'
  if (['txt', 'md'].includes(ext)) return 'icon-bianjiwenzhang_huaban'
  return 'icon-folder'
}

const getFileColorClass = (ext) => {
  if (isImage(ext)) return 'color-image'
  if (isAudio(ext)) return 'color-audio'
  if (isVideo(ext)) return 'color-video'
  if (['pdf'].includes(ext)) return 'color-pdf'
  if (['doc', 'docx'].includes(ext)) return 'color-word'
  if (['xls', 'xlsx'].includes(ext)) return 'color-excel'
  if (['zip', 'rar', '7z', 'tar', 'gz'].includes(ext)) return 'color-archive'
  return 'color-other'
}

/* ========== 数据加载 ========== */
const fetchStats = async () => {
  try {
    const res = await getFileStats()
    stats.value = res.data || []
  } catch (e) {
    console.error('获取统计失败', e)
  }
}

const fetchFiles = async () => {
  loading.value = true
  try {
    const params = {
      page: pagination.page,
      pageSize: pagination.pageSize,
    }
    if (filter.category) params.category = filter.category
    const res = await getFileList(params)
    const data = res.data || {}
    fileList.value = data.records || []
    pagination.total = data.total || 0
  } catch (e) {
    console.error('获取文件列表失败', e)
  } finally {
    loading.value = false
  }
}

/* ========== 分类切换 ========== */
const handleCategoryChange = (cat) => {
  filter.category = cat
  pagination.page = 1
  selectedFiles.value = []
  searchKeyword.value = ''
  fetchFiles()
}

/* ========== 分页 ========== */
const handlePageChange = (p) => {
  pagination.page = p
  selectedFiles.value = []
  fetchFiles()
}

const handleSizeChange = (s) => {
  pagination.pageSize = s
  pagination.page = 1
  selectedFiles.value = []
  fetchFiles()
}

/* ========== 选择 ========== */
const isSelected = (file) => selectedFiles.value.includes(file.name)
const toggleSelect = (file) => {
  const idx = selectedFiles.value.indexOf(file.name)
  if (idx >= 0) {
    selectedFiles.value.splice(idx, 1)
  } else {
    selectedFiles.value.push(file.name)
  }
}
const selectAll = () => {
  if (selectedFiles.value.length === filteredFileList.value.length) {
    selectedFiles.value = []
  } else {
    selectedFiles.value = filteredFileList.value.map((f) => f.name)
  }
}

/* ========== 预览 & Lightbox ========== */
const handlePreview = (file) => {
  previewUrl.value = file.url
  previewName.value = file.name
  if (isImage(file.extension) || isAudio(file.extension) || isVideo(file.extension)) {
    previewType.value = isImage(file.extension) ? 'image' : isAudio(file.extension) ? 'audio' : 'video'
    previewIndex.value = previewableFiles.value.findIndex((f) => f.name === file.name)
    previewVisible.value = true
  } else {
    window.open(file.url, '_blank')
  }
}

const previewPrev = () => {
  if (previewIndex.value > 0) {
    previewIndex.value--
    const f = previewableFiles.value[previewIndex.value]
    previewUrl.value = f.url
    previewName.value = f.name
    previewType.value = isImage(f.extension) ? 'image' : isAudio(f.extension) ? 'audio' : 'video'
  }
}

const previewNext = () => {
  if (previewIndex.value < previewableFiles.value.length - 1) {
    previewIndex.value++
    const f = previewableFiles.value[previewIndex.value]
    previewUrl.value = f.url
    previewName.value = f.name
    previewType.value = isImage(f.extension) ? 'image' : isAudio(f.extension) ? 'audio' : 'video'
  }
}

const handlePreviewKeydown = (e) => {
  if (!previewVisible.value) return
  if (e.key === 'ArrowLeft') previewPrev()
  if (e.key === 'ArrowRight') previewNext()
  if (e.key === 'Escape') previewVisible.value = false
}

/* ========== 复制链接 ========== */
const handleCopyUrl = async (file) => {
  try {
    await navigator.clipboard.writeText(file.url)
    ElMessage.success('链接已复制')
  } catch {
    const input = document.createElement('input')
    input.value = file.url
    document.body.appendChild(input)
    input.select()
    document.execCommand('copy')
    document.body.removeChild(input)
    ElMessage.success('链接已复制')
  }
}

/* ========== 下载 ========== */
const handleDownload = (file) => {
  const a = document.createElement('a')
  a.href = file.url
  a.download = file.name
  a.target = '_blank'
  a.rel = 'noopener noreferrer'
  document.body.appendChild(a)
  a.click()
  document.body.removeChild(a)
}

/* ========== 删除 ========== */
const handleDelete = async (file) => {
  try {
    await ElMessageBox.confirm(`确认删除文件「${file.name}」？删除后不可恢复。`, '删除确认', {
      confirmButtonText: '删除',
      cancelButtonText: '取消',
      type: 'warning',
    })
    await deleteFile(file.name)
    ElMessage.success('删除成功')
    fetchFiles()
    fetchStats()
  } catch (e) {
    if (e !== 'cancel') console.error('删除失败', e)
  }
}

const handleBatchDelete = async () => {
  if (!selectedFiles.value.length) return
  try {
    await ElMessageBox.confirm(
      `确认删除选中的 ${selectedFiles.value.length} 个文件？删除后不可恢复。`,
      '批量删除确认',
      {
        confirmButtonText: '删除',
        cancelButtonText: '取消',
        type: 'warning',
      },
    )
    await batchDeleteFiles(selectedFiles.value)
    ElMessage.success('批量删除成功')
    selectedFiles.value = []
    fetchFiles()
    fetchStats()
  } catch (e) {
    if (e !== 'cancel') console.error('批量删除失败', e)
  }
}

/* ========== 上传 (含拖拽) ========== */
const handleUpload = async (options) => {
  uploadLoading.value = true
  uploadFileName.value = options.file.name
  uploadProgress.value = 0
  try {
    const formData = new FormData()
    formData.append('file', options.file)
    await uploadFileLibrary(formData)
    uploadProgress.value = 100
    ElMessage.success(`上传成功：${options.file.name}`)
    fetchFiles()
    fetchStats()
  } catch (e) {
    ElMessage.error(`上传失败：${options.file.name}`)
  } finally {
    setTimeout(() => {
      uploadLoading.value = false
      uploadProgress.value = 0
      uploadFileName.value = ''
    }, 800)
  }
}

/* 拖拽 */
const handleDragEnter = (e) => {
  e.preventDefault()
  isDragging.value = true
}
const handleDragLeave = (e) => {
  e.preventDefault()
  // 确保离开的是容器
  if (!e.currentTarget.contains(e.relatedTarget)) {
    isDragging.value = false
  }
}
const handleDragOver = (e) => {
  e.preventDefault()
}
const handleDrop = async (e) => {
  e.preventDefault()
  isDragging.value = false
  const files = e.dataTransfer.files
  if (!files.length) return
  for (const file of files) {
    await handleUpload({ file })
  }
}

/* ========== 快捷键 ========== */
onMounted(() => {
  fetchStats()
  fetchFiles()
  document.addEventListener('keydown', handlePreviewKeydown)
})

onUnmounted(() => {
  document.removeEventListener('keydown', handlePreviewKeydown)
})
</script>

<template>
  <div
    class="file-library"
    @dragenter="handleDragEnter"
    @dragleave="handleDragLeave"
    @dragover="handleDragOver"
    @drop="handleDrop"
  >
    <!-- 拖拽上传遮罩 -->
    <Transition name="fade">
      <div v-if="isDragging" class="drag-overlay">
        <div class="drag-overlay-content">
          <div class="drag-icon">
            <span class="iconfont icon-upload"></span>
          </div>
          <p class="drag-title">松开鼠标上传文件</p>
          <p class="drag-hint">支持拖拽多个文件同时上传</p>
        </div>
      </div>
    </Transition>

    <!-- 上传进度条 -->
    <Transition name="slide-down">
      <div v-if="uploadLoading" class="upload-progress-bar">
        <div class="upload-progress-info">
          <span class="iconfont icon-upload"></span>
          <span>正在上传 {{ uploadFileName }}</span>
        </div>
        <el-progress :percentage="uploadProgress" :stroke-width="3" :show-text="false" />
      </div>
    </Transition>

    <!-- 头部区域：存储统计 + 操作 -->
    <div class="header-section">
      <div class="storage-overview">
        <div class="storage-info">
          <span class="storage-label">文件库</span>
          <span class="storage-usage">{{ formatSize(totalUsage) }}</span>
          <span class="storage-count">{{ pagination.total }} 个文件</span>
        </div>
      </div>
    </div>

    <!-- 分类标签 + 操作工具栏 -->
    <div class="controls-section">
      <div class="category-tabs">
        <button
          v-for="cat in categories"
          :key="cat.value"
          :class="['cat-tab', { active: filter.category === cat.value }]"
          @click="handleCategoryChange(cat.value)"
        >
          <span class="cat-tab-label">{{ cat.label }}</span>
          <span v-if="cat.count" class="cat-tab-badge">{{ cat.count }}</span>
        </button>
      </div>

      <div class="toolbar">
        <div class="toolbar-left">
          <el-upload
            :show-file-list="false"
            :http-request="handleUpload"
            :disabled="uploadLoading"
            multiple
          >
            <el-button type="primary" :loading="uploadLoading" class="upload-btn">
              <span class="iconfont icon-upload" style="margin-right: 6px" />
              上传文件
            </el-button>
          </el-upload>

          <Transition name="fade">
            <el-button
              v-if="selectedFiles.length"
              type="danger"
              plain
              @click="handleBatchDelete"
            >
              <span class="iconfont icon-delete" style="margin-right: 4px" />
              删除 ({{ selectedFiles.length }})
            </el-button>
          </Transition>

          <el-button
            v-if="filteredFileList.length"
            plain
            size="default"
            @click="selectAll"
          >
            {{ selectedFiles.length === filteredFileList.length ? '取消全选' : '全选' }}
          </el-button>
        </div>

        <div class="toolbar-right">
          <div class="search-box">
            <span class="iconfont icon-search search-icon"></span>
            <input
              v-model="searchKeyword"
              type="text"
              placeholder="搜索文件名..."
              class="search-input"
            />
          </div>

          <div class="view-toggle">
            <button
              :class="['toggle-btn', { active: viewMode === 'grid' }]"
              @click="viewMode = 'grid'"
              title="网格视图"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <rect x="1" y="1" width="6" height="6" rx="1"/>
                <rect x="9" y="1" width="6" height="6" rx="1"/>
                <rect x="1" y="9" width="6" height="6" rx="1"/>
                <rect x="9" y="9" width="6" height="6" rx="1"/>
              </svg>
            </button>
            <button
              :class="['toggle-btn', { active: viewMode === 'list' }]"
              @click="viewMode = 'list'"
              title="列表视图"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <rect x="1" y="2" width="14" height="2.5" rx="1"/>
                <rect x="1" y="6.75" width="14" height="2.5" rx="1"/>
                <rect x="1" y="11.5" width="14" height="2.5" rx="1"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- 网格视图 -->
    <div v-if="viewMode === 'grid'" v-loading="loading" class="file-grid">
      <div v-if="!loading && filteredFileList.length === 0" class="empty-state">
        <div class="empty-illustration">
          <svg width="120" height="100" viewBox="0 0 120 100" fill="none">
            <rect x="20" y="25" width="80" height="60" rx="6" fill="#f0f2f5" stroke="#d9dce1" stroke-width="1.5"/>
            <path d="M20 35 L50 25 L85 30 L100 25 L100 85 L20 85 Z" fill="#e8eaed" opacity="0.5"/>
            <rect x="35" y="45" width="50" height="6" rx="3" fill="#d9dce1"/>
            <rect x="40" y="57" width="40" height="4" rx="2" fill="#e8eaed"/>
            <circle cx="60" cy="15" r="8" fill="#e8eaed" stroke="#d9dce1" stroke-width="1.5"/>
            <path d="M57 15 L60 12 L63 15" stroke="#d9dce1" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <line x1="60" y1="12" x2="60" y2="19" stroke="#d9dce1" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="empty-title">暂无文件</p>
        <p class="empty-hint">拖拽文件到此处，或点击「上传文件」按钮添加</p>
      </div>

      <div
        v-for="file in filteredFileList"
        :key="file.name"
        :class="['file-card', { selected: isSelected(file) }]"
      >
        <!-- 选择框 -->
        <div class="file-checkbox" @click.stop="toggleSelect(file)">
          <div :class="['checkbox-inner', { checked: isSelected(file) }]">
            <svg v-if="isSelected(file)" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2.5 6L5 8.5L9.5 3.5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <!-- 缩略图区域 -->
        <div class="file-thumb" @click="handlePreview(file)">
          <img
            v-if="isImage(file.extension)"
            :src="file.url"
            :alt="file.name"
            loading="lazy"
          />
          <div v-else :class="['file-icon-placeholder', getFileColorClass(file.extension)]">
            <span :class="['iconfont', getFileIcon(file.extension), 'file-type-icon']"></span>
            <span class="file-ext">.{{ file.extension }}</span>
          </div>
        </div>

        <!-- 文件信息 -->
        <div class="file-info">
          <div class="file-name" :title="file.name">{{ file.name }}</div>
          <div class="file-meta">
            <span>{{ formatSize(file.size) }}</span>
            <span>{{ formatDateShort(file.modifiedTime) }}</span>
          </div>
        </div>

        <!-- 操作按钮浮层 -->
        <div class="file-actions-overlay">
          <button class="overlay-btn" @click.stop="handleCopyUrl(file)" title="复制链接">
            <span class="iconfont icon-link" />
          </button>
          <button class="overlay-btn" @click.stop="handleDownload(file)" title="下载">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor">
              <path d="M7 1v8M7 9L4 6M7 9l3-3M2 12h10" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="overlay-btn danger" @click.stop="handleDelete(file)" title="删除">
            <span class="iconfont icon-delete" />
          </button>
        </div>
      </div>
    </div>

    <!-- 列表视图 -->
    <div v-if="viewMode === 'list'" v-loading="loading" class="file-list-view">
      <div v-if="!loading && filteredFileList.length === 0" class="empty-state">
        <div class="empty-illustration">
          <svg width="120" height="100" viewBox="0 0 120 100" fill="none">
            <rect x="20" y="25" width="80" height="60" rx="6" fill="#f0f2f5" stroke="#d9dce1" stroke-width="1.5"/>
            <rect x="35" y="45" width="50" height="6" rx="3" fill="#d9dce1"/>
            <rect x="40" y="57" width="40" height="4" rx="2" fill="#e8eaed"/>
          </svg>
        </div>
        <p class="empty-title">暂无文件</p>
        <p class="empty-hint">拖拽文件到此处，或点击「上传文件」按钮添加</p>
      </div>

      <div class="list-header" v-if="filteredFileList.length">
        <div class="list-col list-col-check">
          <div
            :class="['checkbox-inner mini', { checked: selectedFiles.length === filteredFileList.length && filteredFileList.length > 0 }]"
            @click="selectAll"
          >
            <svg v-if="selectedFiles.length === filteredFileList.length && filteredFileList.length > 0" width="10" height="10" viewBox="0 0 12 12" fill="none">
              <path d="M2.5 6L5 8.5L9.5 3.5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <div class="list-col list-col-name">文件名</div>
        <div class="list-col list-col-size">大小</div>
        <div class="list-col list-col-date">修改时间</div>
        <div class="list-col list-col-actions">操作</div>
      </div>

      <div
        v-for="file in filteredFileList"
        :key="file.name"
        :class="['list-row', { selected: isSelected(file) }]"
        @click="handlePreview(file)"
      >
        <div class="list-col list-col-check" @click.stop>
          <div
            :class="['checkbox-inner mini', { checked: isSelected(file) }]"
            @click.stop="toggleSelect(file)"
          >
            <svg v-if="isSelected(file)" width="10" height="10" viewBox="0 0 12 12" fill="none">
              <path d="M2.5 6L5 8.5L9.5 3.5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <div class="list-col list-col-name">
          <div class="list-file-icon-wrap">
            <img v-if="isImage(file.extension)" :src="file.url" class="list-thumb" loading="lazy" />
            <span v-else :class="['iconfont', getFileIcon(file.extension), 'list-icon', getFileColorClass(file.extension)]"></span>
          </div>
          <span class="list-file-name" :title="file.name">{{ file.name }}</span>
        </div>
        <div class="list-col list-col-size">{{ formatSize(file.size) }}</div>
        <div class="list-col list-col-date">{{ formatDate(file.modifiedTime) }}</div>
        <div class="list-col list-col-actions" @click.stop>
          <button class="list-action-btn" @click.stop="handleCopyUrl(file)" title="复制链接">
            <span class="iconfont icon-link" />
          </button>
          <button class="list-action-btn" @click.stop="handleDownload(file)" title="下载">
