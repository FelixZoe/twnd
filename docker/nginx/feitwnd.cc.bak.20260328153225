server {
    listen 80 default_server;
    server_name _;
    client_max_body_size 30M;

    root /var/www/feitwnd.cc/html;
    index index.html;

    # RSS Feed - proxy to backend (must be before blog static location)
    location = /blog/rss {
        proxy_pass http://feitwnd_backend/blog/rss;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Blog (base=/blog/)
    location ^~ /blog/ {
        alias /var/www/blog.feitwnd.cc/html/;
        try_files $uri $uri/ /blog/index.html;
        location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }
    location = /blog { return 301 /blog/; }

    # Admin (base=/admin/)
    location ^~ /admin/ {
        alias /var/www/admin.feitwnd.cc/html/;
        try_files $uri $uri/ /admin/index.html;
        location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }
    location = /admin { return 301 /admin/; }

    # CV (base=/cv/)
    location ^~ /cv/ {
        alias /var/www/cv.feitwnd.cc/html/;
        try_files $uri $uri/ /cv/index.html;
        location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }
    location = /cv { return 301 /cv/; }

    # Travelling (开往) - 友链接力
    location ^~ /go/ {
        alias /var/www/go/;
        index index.html;
        try_files $uri $uri/ /go/index.html;
    }
    location = /go { return 301 /go/; }
    # Uploads (local file storage)
    location ^~ /uploads/ {
        alias /var/www/uploads/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        add_header Access-Control-Allow-Origin *;
    }

    # WebSocket
    location /api/ws/ {
        proxy_pass http://feitwnd_backend/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 3600s;
    }

    # API proxy
    location /api/ {
        proxy_pass http://feitwnd_backend/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 30s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
    }

    # Home SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Home static cache
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
